<div style="max-width: 450px; padding: 16px; border: 1px solid #dee2e6; border-radius: 8px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #ffffff; margin-bottom: 20px;">
	<h5 style="margin-top: 0; margin-bottom: 12px; font-weight: bold; font-size: 16px; color: #212529;">
		{{ text_pay_by_method }}
	</h5>
	<div style="padding-top: 8px; padding-bottom: 16px;">
		<img src="{{ payment_method_icon }}" alt="Ifthenpay Gateway" height="38" style="display: block; border: 0;" title="Ifthenpay Gateway"/>
	</div>
	<table style="width: 100%; border-collapse: collapse; border: 1px solid #dee2e6; border-radius: 8px; overflow: hidden; margin-bottom: 12px;">
		<tbody>
			<tr>
				<td style="padding: 12px 8px; border-bottom: 1px solid #dee2e6; font-size: 14px; color: #495057; vertical-align: middle;">
					{{ text_payment_url }}
				</td>
				<td style="padding: 12px 8px; border-bottom: 1px solid #dee2e6; text-align: right; vertical-align: middle;">
					<a href="{{ payment_url }}" target="_blank" style="background-color: #0d6efd; color: #ffffff; padding: 8px 16px; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 13px; display: inline-block;">
						{{ text_goto_gateway_btn }}
					</a>
				</td>
			</tr>
			{% if deadline %}
				<tr>
					<td style="padding: 12px 8px; border-bottom: 1px solid #dee2e6; font-size: 14px; color: #495057;">
						{{ text_deadline }}
					</td>
					<td style="padding: 12px 8px; border-bottom: 1px solid #dee2e6; font-weight: bold; font-size: 14px; text-align: right; color: #212529;">
						{{ deadline }}
					</td>
				</tr>
			{% endif %}
			<tr>
				<td style="padding: 12px 8px; font-size: 14px; color: #495057;">
					{{ text_total_to_pay }}
				</td>
				<td style="padding: 12px 8px; font-weight: bold; font-size: 14px; text-align: right; color: #212529;">
					{{ total }}
				</td>
			</tr>
		</tbody>
	</table>
	<p style="text-align: center; margin-top: 12px; margin-bottom: 0; font-size: 12px; color: #6c757d;">
		{{ text_processed_by_ifthenpay }}
	</p>
</div>
